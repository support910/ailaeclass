# ----------- Build Stage -----------
FROM node:20.19.3-alpine AS builder

WORKDIR /cio
# Install build tools needed for native modules (e.g. @sentry/profiling-node)
RUN apk add --no-cache python3 make g++
# Install pnpm globally (fixed version compatible with Node 20)
RUN npm install -g pnpm@8.15.9

# Copy everything (filtered by .dockerignore)
COPY package.json ./
COPY pnpm-lock.yaml ./
COPY pnpm-workspace.yaml ./
COPY turbo.json ./
COPY packages/tsconfig ./packages/tsconfig
COPY packages/shared ./packages/shared

# Copy the api package.json
COPY apps/dashboard ./apps/dashboard
COPY apps/api ./apps/api

# Install all dependencies (monorepo context)
# --ignore-scripts skips native module compilation (e.g. @sentry/profiling-node)
# which is not required for the dashboard runtime.
RUN pnpm install --ignore-scripts

RUN ls -la

# Set required public env vars for the build (SvelteKit $env/static/public)
# Railway passes Variables as Docker build-args automatically.
ARG PUBLIC_SINGLE_ORG_SITE_NAME
ARG PUBLIC_IS_SELFHOSTED
ARG PUBLIC_SUPABASE_URL
ARG PUBLIC_SUPABASE_ANON_KEY
ARG PRIVATE_SUPABASE_SERVICE_ROLE
ARG PRIVATE_DEEPSEEK_API_KEY
ARG PRIVATE_APP_HOST
ARG PRIVATE_APP_SUBDOMAINS

ENV PUBLIC_SINGLE_ORG_SITE_NAME=${PUBLIC_SINGLE_ORG_SITE_NAME:-""}
ENV PUBLIC_IS_SELFHOSTED=${PUBLIC_IS_SELFHOSTED:-true}
ENV PUBLIC_SUPABASE_URL=${PUBLIC_SUPABASE_URL:-https://kiqzanfkpivkuvlvxqsp.supabase.co}
ENV PUBLIC_SUPABASE_ANON_KEY=${PUBLIC_SUPABASE_ANON_KEY}
ENV PRIVATE_SUPABASE_SERVICE_ROLE=${PRIVATE_SUPABASE_SERVICE_ROLE}
ENV PRIVATE_DEEPSEEK_API_KEY=${PRIVATE_DEEPSEEK_API_KEY}
ENV PRIVATE_APP_HOST=${PRIVATE_APP_HOST:-5gnumultimedia.com}
ENV PRIVATE_APP_SUBDOMAINS=${PRIVATE_APP_SUBDOMAINS:-app}

# Build API first (dashboard depends on @cio/api/rpc-types)
RUN NODE_OPTIONS="--max-old-space-size=3072" pnpm --filter @cio/api build

# Build the dashboard app (bypass turbo so env vars flow directly to vite)
RUN NODE_OPTIONS="--max-old-space-size=3072" PUBLIC_IS_SELFHOSTED=true pnpm --filter @cio/dashboard build

# ----------- Production Stage -----------
FROM node:20.19.3-alpine AS runner

WORKDIR /app

# Re-declare build args so they are available in this stage for ENV defaults
ARG PUBLIC_SINGLE_ORG_SITE_NAME
ARG PUBLIC_SUPABASE_URL
ARG PUBLIC_SUPABASE_ANON_KEY
ARG PRIVATE_SUPABASE_SERVICE_ROLE
ARG PRIVATE_DEEPSEEK_API_KEY
ARG PRIVATE_APP_HOST
ARG PRIVATE_APP_SUBDOMAINS

# Install pnpm and turbo before switching to non-root user
RUN npm install -g pnpm@8.15.9 turbo@1.10.16

# Don't run production as root
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 cio-user
USER cio-user

# Copy the built dashboard app
COPY --from=builder --chown=cio-user:nodejs ./cio/apps/dashboard ./apps/dashboard
# Copy api dist because workspace symlink in node_modules may point there at runtime
COPY --from=builder --chown=cio-user:nodejs ./cio/apps/api ./apps/api
COPY --from=builder --chown=cio-user:nodejs ./cio/node_modules ./node_modules
COPY --from=builder --chown=cio-user:nodejs ./cio/package.json ./package.json
COPY --from=builder --chown=cio-user:nodejs ./cio/turbo.json ./turbo.json
COPY --from=builder --chown=cio-user:nodejs ./cio/pnpm-workspace.yaml ./pnpm-workspace.yaml

# Expose the port (default for SvelteKit Node adapter)
EXPOSE 3082

# Set environment variables for production
# PUBLIC_ vars must be available at runtime because the app uses $env/dynamic/public
ENV PORT=3082 \
    NODE_ENV=production \
    PUBLIC_IS_SELFHOSTED=true \
    PUBLIC_SUPABASE_URL=${PUBLIC_SUPABASE_URL:-https://kiqzanfkpivkuvlvxqsp.supabase.co} \
    PUBLIC_SUPABASE_ANON_KEY=${PUBLIC_SUPABASE_ANON_KEY} \
    PRIVATE_SUPABASE_SERVICE_ROLE=${PRIVATE_SUPABASE_SERVICE_ROLE} \
    PRIVATE_DEEPSEEK_API_KEY=${PRIVATE_DEEPSEEK_API_KEY} \
    PRIVATE_APP_HOST=${PRIVATE_APP_HOST:-5gnumultimedia.com} \
    PRIVATE_APP_SUBDOMAINS=${PRIVATE_APP_SUBDOMAINS:-app} \
    PUBLIC_SINGLE_ORG_SITE_NAME=${PUBLIC_SINGLE_ORG_SITE_NAME:-""} \
    NODE_OPTIONS="--max-old-space-size=2048"

# Start the app
CMD ["pnpm", "dashboard:start"]